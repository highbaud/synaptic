# Synaptic secrets only. Copy to .env and fill in. NEVER commit .env.
# API keys live here (or your OS keychain). They are never written to your vault.

# --- LLM provider keys (only needed if you enable that provider in config.yaml) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# --- Behavior overrides (optional; config.yaml is the source of truth) ---
# SYNAPTIC_LOCAL_ONLY=true   # hard block all outbound network to external LLM providers
